    {name:"SelfLoops",emoji:"🔄",tag:"Wearable Analytics",tagline:"Analytics avanzados para wearables y dispositivos",description:"Plataforma de análisis de datos de wearables para grupos y organizaciones. Convierte datos de dispositivos en insights accionables.",ideal:["Equipos deportivos","Corporativo","Centros de salud"],pitch:"Los datos sin análisis no sirven. SelfLoops convierte números en decisiones."},
    {name:"Amalgama",emoji:"⚙️",tag:"Tech Integration",tagline:"Integración tecnológica para el sector fitness",description:"Soluciones de integración tecnológica que conectan sistemas dispares del ecosistema fitness y wellness.",ideal:["Cadenas fitness","Operadores multi-site","Tech companies"],pitch:"El problema de integración es universal. Amalgama es la solución invisible que vale oro."},
    {name:"Shark Digital",emoji:"🦈",tag:"Digital Marketing",tagline:"Marketing digital especializado en fitness",description:"Agencia de marketing digital enfocada en el sector fitness y wellness. Estrategias de captación y retención de clientes para el mercado específico.",ideal:["Gimnasios","Estudios","Marcas fitness"],pitch:"Marketing genérico no funciona en fitness. Shark habla el idioma del sector."},
    {name:"Lemin",emoji:"📈",tag:"Leadership Analytics",tagline:"Analytics de liderazgo para organizaciones fitness",description:"Plataforma de análisis de performance y liderazgo organizacional. Ayuda a los operadores fitness a tomar decisiones basadas en datos de gestión.",ideal:["Cadenas fitness","Franquicias","Grupos empresariales"],pitch:"Los mejores operadores fitness toman decisiones con datos. Lemin los genera."},
  ],
  services:[
    {name:"Mironova Interior Design",emoji:"🏛️",tag:"Interior Design",tagline:"Diseño de interiores especializado en fitness & wellness",description:"Estudio de diseño de interiores con expertise en espacios fitness, wellness y hospitalidad. Transforma espacios en experiencias.",ideal:["Nuevas aperturas","Renovaciones premium","Hoteles wellness"],pitch:"El espacio vende antes que el equipamiento. Mironova crea espacios que enamoran."},
    {name:"FuCo Care Robotics",emoji:"🤖",tag:"Care Robotics",tagline:"Robótica de cuidado para salud y wellness",description:"Soluciones robóticas para el sector salud y bienestar. Tecnología de frontera para centros médicos y wellness de alta gama.",ideal:["Clínicas","Centros médicos","Longevity clinics"],pitch:"La robótica en salud no es el futuro — es el presente. Los early adopters ganan."},
  ]
};

const STRATEGIES = [
  {icon:"🔗",title:"La Estrategia del Combo",subtitle:"Hardware + Software = Retención máxima",badge:"ALTO ROI",desc:"Nunca vendas solo hardware o solo software. El combo crea dependencia positiva y aumenta el ticket promedio 2–3x.",steps:["Identifica el pain principal del cliente (gestión, resultados, diferenciación)","Propón el hardware que resuelve el problema visible","Añade el software que lo potencia y digitaliza","Presenta el ROI combinado como una sola inversión"],example:"Wiemspro (EMS) + Harbiz (gestión) + Lemin (analytics) = Centro EMS llave en mano"},
  {icon:"🎯",title:"La Estrategia Vertical",subtitle:"Especialización por tipo de cliente",badge:"REFERIDOS",desc:"Domina un vertical antes de expandirte. La especialización genera referidos naturales y posicionamiento de autoridad.",steps:["Elige un vertical: fisioterapia, wellness, boutique fitness, corporativo","Aprende el lenguaje específico del sector","Construye casos de éxito en ese vertical","Usa cada cliente como referencia para el siguiente"],example:"Fisioterapia: BASI + CUBE Sports + SelfLoops = Solución clínica completa"},
  {icon:"💎",title:"La Estrategia Premium",subtitle:"Vende la experiencia, no el producto",badge:"TICKET ALTO",desc:"Los mejores clientes compran visión, no catálogos. Presenta FitLink como asesoría estratégica, no como distribuidora.",steps:["Abre con preguntas sobre el proyecto, no sobre el presupuesto","Diseña una propuesta a medida con 3–5 productos complementarios","Incluye siempre Mironova (diseño) en proyectos de apertura","Negocia paquetes, nunca productos sueltos"],example:"Hotel 5*: Sparkfield + ICAROS + POOLBIKING + Mironova = Wellness Experience única"},
  {icon:"📱",title:"La Estrategia SaaS First",subtitle:"Empieza con software, escala con hardware",badge:"RELACIÓN LARGA",desc:"El software entra fácil, crea relación, genera confianza. El hardware viene después. El software es la puerta.",steps:["Empieza la conversación con Harbiz o WizFit AI","Demuestra valor rápido con una prueba o demo funcional","Identifica carencias en el espacio físico durante el proceso","Propón el equipamiento como upgrade natural"],example:"Harbiz (gestión) → diagnóstico → WizFit AI (coaching) → Bodytone (equipamiento faltante)"},
  {icon:"⚡",title:"La Estrategia de Urgencia",subtitle:"El mercado no espera",badge:"CIERRE RÁPIDO",desc:"Usa datos de mercado y tendencias para crear urgencia genuina. No urgencia artificial — urgencia real basada en oportunidad.",steps:["Lleva datos: 'El mercado EMS en DACH crece X% anual'","Señala el costo de no decidir: competidores que ya adoptaron","Propón un piloto de bajo riesgo para comenzar","Define un deadline claro ligado a disponibilidad o precio"],example:"ROOK: 'Tu competidor ya integra wearables. Cada mes sin datos es market share perdido'"},
];

const TIMELINE = [
  {day:"Día 1–3",icon:"📚",title:"Inmersión de Producto",desc:"Conoce el portfolio completo. Identifica tus 3 productos favoritos para comenzar."},
  {day:"Día 4–7",icon:"🎯",title:"Elige tu Vertical",desc:"Decide en qué mercado quieres especializarte primero."},
  {day:"Semana 2",icon:"📞",title:"Primeros Contactos",desc:"5 llamadas de exploración sin objetivo de venta. Solo escucha."},
  {day:"Semana 3",icon:"📋",title:"Primera Propuesta",desc:"Prepara una propuesta combo para tu mejor prospecto."},
  {day:"Mes 2",icon:"🏆",title:"Primer Cierre",desc:"Con el pipeline activo, el primer cierre llega. El momentum empieza aquí."},
];

const MANIFESTO_LINES = [
  "Cada gimnasio que equipas mejor mejora la vida de sus miembros.",
  "Cada software que implementas convierte datos en decisiones más inteligentes.",
  "Cada solución que recomiendas construye tu reputación como experto del sector.",
  "Tu éxito y el éxito de tus clientes son la misma cosa.",
];

// ── STATE ──
let currentSection = 0;
let currentCat = 'hardware';
let currentRM = 0;

// ── INIT ──
function init(){
  buildNavDots();
  buildPartnerGrid('hardware');
  buildStrategies();
  buildRoadmap();
  buildManifesto();
  showSection(0);
}

function buildNavDots(){
  const c = document.getElementById('nav-dots');
  c.innerHTML = '';
  SECTIONS.forEach((_,i)=>{
    const d = document.createElement('div');
    d.className = 'ndot' + (i===0?' active':'');
    d.onclick = ()=>showSection(i);
    c.appendChild(d);
  });
}

function updateNavDots(){
  document.querySelectorAll('.ndot').forEach((d,i)=>{
    d.classList.toggle('active', i===currentSection);
  });
}

function buildPartnerGrid(cat){
  const g = document.getElementById('partner-grid');
  g.innerHTML='';
  PARTNERS[cat].forEach(p=>{
    const d = document.createElement('div');
    d.className = 'partner-card';
    d.innerHTML = `<div class="p-emoji">${p.emoji}</div><div style="margin-bottom:6px;"><span class="badge" style="font-size:8px;background:rgba(218,195,155,.4);color:var(--dark);">${p.tag}</span></div><div class="p-name">${p.name}</div><div class="p-tag-line">${p.tagline}</div>`;
    d.onclick = ()=>openModal(p);
    g.appendChild(d);
  });
}

function switchCat(cat, btn){
  currentCat = cat;
  document.querySelectorAll('.cat-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  buildPartnerGrid(cat);
}

function buildStrategies(){
  const c = document.getElementById('strat-list');
  STRATEGIES.forEach((s,i)=>{
    const div = document.createElement('div');
    div.className='strat-card';
    div.innerHTML=`
      <div class="strat-header" onclick="toggleStrat(${i},this)">
        <div class="strat-left">
          <div class="strat-emoji">${s.icon}</div>
          <div>
            <div class="strat-title">${s.title}</div>
            <div class="strat-subtitle">${s.subtitle}</div>
          </div>
        </div>
        <div class="strat-right">
          <span class="badge">${s.badge}</span>
          <span class="strat-arrow">›</span>
        </div>
      </div>
      <div class="strat-body" id="strat-body-${i}">
        <div class="strat-desc">${s.desc}</div>
        ${s.steps.map((st,j)=>`<div class="step-row"><div class="step-num">${j+1}</div><div class="step-text">${st}</div></div>`).join('')}
        <div class="example-box">
          <div class="example-label">EJEMPLO REAL</div>
          <div class="example-text">${s.example}</div>
        </div>
      </div>`;
    c.appendChild(div);
  });
}

function toggleStrat(i, header){
  const body = document.getElementById('strat-body-'+i);
  const arrow = header.querySelector('.strat-arrow');
  const open = body.style.display==='block';
  body.style.display = open?'none':'block';
  arrow.style.transform = open?'none':'rotate(90deg)';
}

function buildRoadmap(){
  const tabs = document.getElementById('rm-tabs');
  TIMELINE.forEach((t,i)=>{
    const btn = document.createElement('button');
    btn.className='rm-tab'+(i===0?' active':'');
    btn.textContent=t.day;
    btn.onclick=()=>selectRM(i,btn);
    tabs.appendChild(btn);
  });
  renderRM(0);
}

function selectRM(i,btn){
  currentRM=i;
  document.querySelectorAll('.rm-tab').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  renderRM(i);
}

function renderRM(i){
  const t = TIMELINE[i];
  document.getElementById('rm-card').innerHTML=`
    <div class="rm-icon">${t.icon}</div>
    <div class="rm-day">${t.day.toUpperCase()}</div>
    <div class="rm-title">${t.title}</div>
    <div class="rm-desc">${t.desc}</div>`;
}

function buildManifesto(){
  const c = document.getElementById('manifesto-list');
  MANIFESTO_LINES.forEach((l,i)=>{
    const d=document.createElement('div');
    d.className='manifesto-item';
    d.id='ml-'+i;
    d.innerHTML=`<div class="m-dot"></div><div class="m-text">${l}</div>`;
    c.appendChild(d);
  });
}

function revealManifesto(){
  MANIFESTO_LINES.forEach((_,i)=>{
    setTimeout(()=>{
      const el=document.getElementById('ml-'+i);
      if(el){ el.classList.add('revealed'); el.style.animationDelay=i*0.15+'s'; }
    }, i*150);
  });
}

// ── NAVIGATION ──
function showSection(n){
  const sections=['s0','s1','s2','s3','s4','s5'];
  sections.forEach(id=>{
    const el=document.getElementById(id);
    el.style.display='none';
    el.classList.remove('fade-up');
  });
  currentSection=n;
  const el=document.getElementById('s'+n);
  el.style.display='block';
  void el.offsetWidth;
  el.classList.add('fade-up');

  document.getElementById('btn-prev').disabled = n===0;
  document.getElementById('btn-next').disabled = n===sections.length-1;
  document.getElementById('section-label').textContent = SECTIONS[n];
  updateNavDots();

  // scroll to top
  document.getElementById('scroll-area').scrollTo({top:0,behavior:'smooth'});

  if(n===5) setTimeout(revealManifesto,400);
}

function navigate(dir){
  const next = currentSection+dir;
  if(next<0||next>5) return;
  showSection(next);
}

// ── MODAL ──
function openModal(p){
  document.getElementById('modal-emoji').textContent=p.emoji;
  document.getElementById('modal-name').textContent=p.name;
  document.getElementById('modal-badge').innerHTML=`<span class="badge">${p.tag}</span>`;
  document.getElementById('modal-desc').textContent=p.description;
  document.getElementById('modal-chips').innerHTML=p.ideal.map(t=>`<span class="tag-chip">${t}</span>`).join('');
  document.getElementById('modal-pitch').textContent='"'+p.pitch+'"';
  document.getElementById('modal-overlay').classList.add('open');
  document.body.style.overflow='hidden';
}

function closeModal(e){
  if(e.target===document.getElementById('modal-overlay')) closeModalDirect();
}

function closeModalDirect(){
  document.getElementById('modal-overlay').classList.remove('open');
  document.body.style.overflow='';
}

// ── SWIPE SUPPORT ──
let touchStartX=0, touchStartY=0;
document.getElementById('scroll-area').addEventListener('touchstart',e=>{
  touchStartX=e.touches[0].clientX;
  touchStartY=e.touches[0].clientY;
},{passive:true});
document.getElementById('scroll-area').addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-touchStartX;
  const dy=e.changedTouches[0].clientY-touchStartY;
  if(Math.abs(dx)>Math.abs(dy)*1.5 && Math.abs(dx)>50){
    navigate(dx<0?1:-1);
  }
},{passive:true});

init();
</script>
