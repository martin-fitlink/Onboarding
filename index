  software:[
    {name:"ROOK",emoji:"📡",tag:"Health Data API",tagline:"La capa de datos de salud para cualquier app",description:"API que conecta wearables y dispositivos de salud con cualquier aplicación. Infraestructura crítica para el ecosistema health-tech.",ideal:["Apps de salud","Seguros","Plataformas fitness"],pitch:"Si tienen una app y usuarios activos, necesitan ROOK. El argumento de venta se escribe solo."},
